# L2 Result Refiner — API Keys & Settings
# All config is read from this file — zero hardcoded values in code.

GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
GROQ_TEMPERATURE=0.1
MAX_INPUT_LENGTH=4096

# Embedding model for corpus search
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Cross-encoder for reranking (small model ~80MB)
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Retrieval defaults
TOP_K=10
RERANK_TOP_K=5

# Sliding window: score threshold and token budget
SLIDING_WINDOW_THRESHOLD=0.3
SLIDING_WINDOW_TOKEN_BUDGET=4096
