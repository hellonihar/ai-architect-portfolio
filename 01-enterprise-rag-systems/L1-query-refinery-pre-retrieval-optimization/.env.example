# L1 Query Refinery — API Keys & Settings
# All config is read from this file — zero hardcoded values in code.

GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
GROQ_TEMPERATURE=0.3
MAX_INPUT_LENGTH=4096

# Embedding model for HyDE strategy
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Default strategy: auto, query_rewriter, hyde, multi_query, query_decomposer
REFINERY_DEFAULT_STRATEGY=auto

# Multi-query: number of query variants to generate
MULTI_QUERY_VARIANTS=3

# HyDE: LLM temperature for hypothetical document generation
HYDE_TEMPERATURE=0.3

# Query rewriter: include conversation history toggle
REWRITER_USE_HISTORY=true
